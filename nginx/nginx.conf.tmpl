events {}

http {
    include      /etc/nginx/mime.types;
    default_type application/octet-stream;

    upstream auth_upstream {
        {{- range service "auth-service" }}
        server {{ .Address }}:{{ .Port }};
        {{- end }}
    }

    upstream robot_upstream {
        {{- range service "robot-service" }}
        server {{ .Address }}:{{ .Port }};
        {{- end }}
    }

    upstream mission_upstream {
        {{- range service "mission-service" }}
        server {{ .Address }}:{{ .Port }};
        {{- end }}
    }

    server {
        listen 80;

        # ── Frontend ──────────────────────────────────────────
        location / {
            root  /usr/share/nginx/html;
            index index.html;
            try_files $uri $uri/ /index.html;
        }

        # ── API proxy ─────────────────────────────────────────
        location /auth {
            proxy_pass       http://auth_upstream;
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header Cookie            $http_cookie;
            proxy_pass_header Set-Cookie;
        }

        location /robots {
            proxy_pass       http://robot_upstream;
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header Cookie            $http_cookie;
        }

        location /missions {
            proxy_pass       http://mission_upstream;
            proxy_set_header Host              $host;
            proxy_set_header X-Real-IP         $remote_addr;
            proxy_set_header Cookie            $http_cookie;
        }
    }
}