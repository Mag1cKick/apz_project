# NOTE: This .env is committed intentionally for academic/demo purposes.
# In production, this file should never be committed to version control.

# ─────────────────────────────────────────
# Image versions
# ─────────────────────────────────────────
CONSUL_VERSION=1.18
POSTGRES_VERSION=15-alpine
MONGO_VERSION=6
REDIS_VERSION=7-alpine
HAZELCAST_VERSION=5.3

# ─────────────────────────────────────────
# Service ports (single source of truth)
# ─────────────────────────────────────────
AUTH_SERVICE_PORT=8001
ROBOT_SERVICE_PORT=8002
MISSION_SERVICE_PORT=8003

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_SECRET=robotops-super-secret-key-change-in-production
JWT_EXPIRE_MINUTES=60

# ─────────────────────────────────────────
# PostgreSQL — Auth
# ─────────────────────────────────────────
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=auth_pass
POSTGRES_AUTH_DB=auth_db
POSTGRES_AUTH_URL=postgresql+asyncpg://auth_user:auth_pass@auth-db:5432/auth_db

# ─────────────────────────────────────────
# PostgreSQL — Missions
# ─────────────────────────────────────────
POSTGRES_MISSION_USER=mission_user
POSTGRES_MISSION_PASSWORD=mission_pass
POSTGRES_MISSION_DB=mission_db
POSTGRES_MISSION_URL=postgresql+asyncpg://mission_user:mission_pass@mission-db:5432/mission_db

# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
MONGO_HOST_1=mongo1
MONGO_HOST_2=mongo2
MONGO_HOST_3=mongo3
MONGO_PORT=27017
MONGO_REPLICASET=rs0
MONGO_DB=robot_db
MONGO_URI=mongodb://mongo1:27017,mongo2:27017,mongo3:27017/?replicaSet=rs0

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://redis:6379


HAZELCAST_CLUSTER_NAME=robotops-hz